# .env.example — Copy this to .env and fill in your values
#
#   cp .env.example .env
#   then edit .env
#
# Only ANTHROPIC_API_KEY is required. All other variables are optional.

# ── Anthropic API ─────────────────────────────────────────────────────────────

# Your Anthropic API key — required for Claude meeting notes generation.
# Standard key: get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Custom API base URL — optional.
# Use this if you access Claude through a corporate proxy or AI gateway
# (e.g. SAP AI Core, Azure OpenAI proxy, or a local LiteLLM server).
# Leave commented out to use the default Anthropic endpoint.
# ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/

# Claude model to use for meeting notes generation — optional.
# Default: claude-sonnet-4-6
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Whisper / Transcription ───────────────────────────────────────────────────

# mlx-whisper model to use for transcription — optional.
# Model is downloaded once from HuggingFace to ~/.cache/huggingface/
# Default (fast, ~145 MB, English only):
# WHISPER_MODEL=mlx-community/whisper-base.en-mlx
#
# More accurate, larger models:
# WHISPER_MODEL=mlx-community/whisper-small.en-mlx    # ~465 MB
# WHISPER_MODEL=mlx-community/whisper-medium.en-mlx   # ~1.5 GB
#
# Multilingual (for non-English meetings):
# WHISPER_MODEL=mlx-community/whisper-base-mlx
# WHISPER_MODEL=mlx-community/whisper-small-mlx
